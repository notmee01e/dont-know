            Position  = UDim2.new(0, 14, 0, 26),
            TextColor3 = Theme.TextSecondary,
            TextSize  = 10,
            ZIndex    = notif.ZIndex + 2,
        })

        -- Slide in
        notif.Position = UDim2.new(1, 10, 1, -80)
        tween(notif, {Position = UDim2.new(1, -276, 1, -80)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        task.delay(duration, function()
            tween(notif, {Position = UDim2.new(1, 10, 1, -80)}, 0.25)
            task.delay(0.25, function()
                notif:Destroy()
            end)
        end)
    end

