        -- Slider
        function tabAPI:AddSlider(sliderLabel, settings, callback)
            sliderLabel = tostring(sliderLabel or "Slider")
            callback    = type(callback) == "function" and callback or function() end
            settings    = settings or {}
            local min   = settings.min or 0
            local max   = settings.max or 100
            local default = settings.default or min
            local suffix  = settings.suffix or ""

            local el = frame(scroller, {
                Size             = UDim2.new(1, 0, 0, 46),
                BackgroundColor3 = Theme.ElementBg,
                ZIndex           = scroller.ZIndex + 1,
            })
            corner(el, 7)
            stroke(el, Theme.ElementBorder, 1, 0.6)

            label(el, {
                Text      = string.upper(sliderLabel),
                Size      = UDim2.new(0.7, 0, 0, 20),
                Position  = UDim2.new(0, 12, 0, 4),
                TextColor3 = Theme.TextPrimary,
                TextSize  = 12,
                ZIndex    = el.ZIndex + 1,
            })

            local valLabel = label(el, {
                Text      = tostring(default) .. suffix,
                Size      = UDim2.new(0.3, -12, 0, 20),
                Position  = UDim2.new(0.7, 0, 0, 4),
                TextColor3 = Theme.AccentLight,
                TextSize  = 12,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex    = el.ZIndex + 1,
            })

            -- Track bg
            local trackBg = frame(el, {
                Size             = UDim2.new(1, -24, 0, 4),
                Position         = UDim2.new(0, 12, 0, 32),
                BackgroundColor3 = Theme.ElementHover,
                ZIndex           = el.ZIndex + 1,
            })
            corner(trackBg, 2)

            -- Fill
            local fill = frame(trackBg, {
                Size             = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = Theme.AccentLight,
                ZIndex           = trackBg.ZIndex + 1,
            })
            corner(fill, 2)

            -- Knob
            local knob = frame(trackBg, {
                Size             = UDim2.fromOffset(12, 12),
                Position         = UDim2.new(0, -6, 0.5, -6),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                ZIndex           = trackBg.ZIndex + 2,
            })
            corner(knob, 6)

            local currentVal = default
            local function setPct(pct)
                pct         = math.clamp(pct, 0, 1)
                currentVal  = math.floor(min + (max - min) * pct)
                fill.Size   = UDim2.new(pct, 0, 1, 0)
                knob.Position = UDim2.new(pct, -6, 0.5, -6)
                valLabel.Text = tostring(currentVal) .. suffix
                pcall(callback, currentVal)
            end

            -- Init
            setPct((default - min) / (max - min))

            local dragging = false
            trackBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            RunService.Heartbeat:Connect(function()
                if dragging then
                    local mouseX = UserInputService:GetMouseLocation().X
                    local pct = (mouseX - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X
                    setPct(pct)
                end
            end)

            local sliderAPI = {}
            function sliderAPI:Set(val)
                setPct((val - min) / (max - min))
            end
            function sliderAPI:Get() return currentVal end
            return sliderAPI, el
        end

        -- Dropdown
        function tabAPI:AddDropdown(dropLabel, items, callback)
            dropLabel = tostring(dropLabel or "Dropdown")
            callback  = type(callback) == "function" and callback or function() end
            items     = items or {}

            local el = frame(scroller, {
                Size             = UDim2.new(1, 0, 0, 32),
