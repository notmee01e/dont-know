--// HELPERS
local bindingActive = false
local connections   = {}
local windowCount   = 0

local function tween(obj, props, t, style, dir)
    local info = TweenInfo.new(t or 0.15, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out)
    TweenService:Create(obj, info, props):Play()
end

local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color        = color or Color3.fromRGB(75, 30, 140)
    s.Thickness    = thickness or 1
    s.Transparency = transparency or 0
    s.Parent       = parent
    return s
end

local function frame(parent, props)
    local f = Instance.new("Frame")
    f.BackgroundTransparency = 0
    f.BorderSizePixel = 0
    for k, v in pairs(props or {}) do f[k] = v end
    f.Parent = parent
    return f
end

local function label(parent, props)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.BorderSizePixel = 0
    l.Font = Enum.Font.GothamBold
    l.TextSize = 13
    l.TextColor3 = Theme.TextPrimary
    l.TextXAlignment = Enum.TextXAlignment.Left
    for k, v in pairs(props or {}) do l[k] = v end
    l.Parent = parent
    return l
end

local function button(parent, props)
    local b = Instance.new("TextButton")
    b.BackgroundTransparency = 1
    b.BorderSizePixel = 0
    b.AutoButtonColor = false
    b.Font = Enum.Font.GothamBold
    b.TextSize = 13
    b.TextColor3 = Theme.TextPrimary
    for k, v in pairs(props or {}) do b[k] = v end
    b.Parent = parent
    return b
end

local function imageLabel(parent, props)
    local i = Instance.new("ImageLabel")
    i.BackgroundTransparency = 1
    i.BorderSizePixel = 0
    for k, v in pairs(props or {}) do i[k] = v end
    i.Parent = parent
    return i
end

local function getMousePos()
    local pos = UserInputService:GetMouseLocation()
    return Vector2.new(pos.X, pos.Y - 36)
end

-- Pulse border animation
local function animateBorder(uiStroke)
    local colors = {
        Color3.fromRGB(180, 80, 255),
        Color3.fromRGB(120, 40, 220),
        Color3.fromRGB(210, 120, 255),
        Color3.fromRGB(90, 20, 180),
    }
    local idx = 1
    task.spawn(function()
        while uiStroke and uiStroke.Parent do
            idx = (idx % #colors) + 1
            tween(uiStroke, {Color = colors[idx], Transparency = 0}, 1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(1.4)
            tween(uiStroke, {Color = Theme.WindowBorder, Transparency = 0.5}, 1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(1.4)
        end
    end)
end

--// TOGGLE KEY
UserInputService.InputBegan:Connect(function(input, processed)
    if input.KeyCode == Enum.KeyCode.RightShift and not bindingActive then
        Root.Enabled = not Root.Enabled
    end
end)

--// LIBRARY
local Library = {}

function Library:AddWindow(title, options)
    windowCount = windowCount + 1
    options = options or {}
    title   = tostring(title or "Violet Thunder")

    local winW = options.width  or 560
    local winH = options.height or 360
    local sideW = 140

    -- ── Main Window Frame ──────────────────────────────────────
    local win = frame(Root, {
        Name             = "Window_" .. windowCount,
        Size             = UDim2.fromOffset(winW, winH),
        Position         = UDim2.fromOffset(80 + (windowCount-1)*30, 80 + (windowCount-1)*30),
        BackgroundColor3 = Theme.WindowBg,
        ZIndex           = windowCount * 10,
        ClipsDescendants = false,
    })
    corner(win, 10)
    local winBorder = stroke(win, Theme.WindowBorder, 1.5, 0.3)
    animateBorder(winBorder)

    -- Drop shadow
    local shadow = imageLabel(Root, {
        Name             = "Shadow",
        Size             = UDim2.new(1, 30, 1, 30),
        Position         = UDim2.new(0, -15, 0, -15),
        ZIndex           = win.ZIndex - 1,
        Image            = "rbxassetid://6014261993",
        ImageColor3      = Color3.fromRGB(0, 0, 0),
        ImageTransparency = 0.55,
        ScaleType        = Enum.ScaleType.Slice,
        SliceCenter      = Rect.new(49, 49, 450, 450),
    })
    shadow.Parent = win

    -- ── Title Bar ──────────────────────────────────────────────
    local titleBar = frame(win, {
        Name             = "TitleBar",
        Size             = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = Theme.TitleBar,
        ZIndex           = win.ZIndex + 1,
    })
    -- Round only top corners
    local titleCorner = Instance.new("UICorner")
    titleCorner.CornerRadius = UDim.new(0, 10)
    titleCorner.Parent = titleBar

    -- Cover bottom corners of titlebar
    local titleFix = frame(titleBar, {
        Size             = UDim2.new(1, 0, 0.5, 0),
        Position         = UDim2.new(0, 0, 0.5, 0),
        BackgroundColor3 = Theme.TitleBar,
        ZIndex           = titleBar.ZIndex,
    })

    -- Title bar border bottom
    local titleBorderBottom = frame(titleBar, {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Theme.SidebarBorder,
        ZIndex           = titleBar.ZIndex + 1,
    })

    -- Window icon / logo dot
    local logoDot = frame(titleBar, {
        Size             = UDim2.fromOffset(8, 8),
        Position         = UDim2.new(0, 14, 0.5, -4),
        BackgroundColor3 = Theme.AccentLight,
        ZIndex           = titleBar.ZIndex + 2,
    })
    corner(logoDot, 4)
    -- Logo pulse
    task.spawn(function()
        while logoDot and logoDot.Parent do
            tween(logoDot, {BackgroundColor3 = Theme.Accent}, 1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(1)
            tween(logoDot, {BackgroundColor3 = Theme.AccentLight}, 1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(1)
        end
    end)

    -- Title text
    label(titleBar, {
        Text             = string.upper(title),
        Size             = UDim2.new(1, -120, 1, 0),
        Position         = UDim2.new(0, 30, 0, 0),
        TextColor3       = Theme.TextPrimary,
        TextSize         = 13,
        ZIndex           = titleBar.ZIndex + 2,
    })

    -- Close button
    local closeBtn = button(titleBar, {
        Text             = "✕",
        Size             = UDim2.fromOffset(28, 28),
        Position         = UDim2.new(1, -34, 0.5, -14),
        BackgroundColor3 = Color3.fromRGB(180, 40, 80),
        BackgroundTransparency = 1,
        TextColor3       = Theme.TextMuted,
        TextSize         = 14,
        ZIndex           = titleBar.ZIndex + 3,
    })
    corner(closeBtn, 6)
    closeBtn.MouseEnter:Connect(function()
        tween(closeBtn, {BackgroundTransparency = 0.2, TextColor3 = Color3.fromRGB(255,255,255)}, 0.1)
    end)
    closeBtn.MouseLeave:Connect(function()
        tween(closeBtn, {BackgroundTransparency = 1, TextColor3 = Theme.TextMuted}, 0.1)
    end)
    closeBtn.MouseButton1Click:Connect(function()
        Root.Enabled = false
    end)

    -- Minimize button
    local minBtn = button(titleBar, {
        Text             = "─",
        Size             = UDim2.fromOffset(28, 28),
        Position         = UDim2.new(1, -66, 0.5, -14),
        BackgroundTransparency = 1,
        TextColor3       = Theme.TextMuted,
        TextSize         = 14,
        ZIndex           = titleBar.ZIndex + 3,
    })
    corner(minBtn, 6)
    local isMinimized = false
    local savedH = winH
    minBtn.MouseEnter:Connect(function()
        tween(minBtn, {BackgroundTransparency = 0.7, TextColor3 = Theme.TextSecondary}, 0.1)
        minBtn.BackgroundColor3 = Theme.ElementBg
    end)
    minBtn.MouseLeave:Connect(function()
        tween(minBtn, {BackgroundTransparency = 1, TextColor3 = Theme.TextMuted}, 0.1)
    end)
    minBtn.MouseButton1Click:Connect(function()
        isMinimized = not isMinimized
        if isMinimized then
            savedH = win.AbsoluteSize.Y
            tween(win, {Size = UDim2.fromOffset(win.AbsoluteSize.X, 36)}, 0.2, Enum.EasingStyle.Quad)
        else
            tween(win, {Size = UDim2.fromOffset(win.AbsoluteSize.X, savedH)}, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        end
    end)

    -- Draggable
    do
        local dragging, dragStart, startPos = false, nil, nil
        titleBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging  = true
                dragStart = input.Position
                startPos  = win.Position
            end
        end)
        titleBar.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        RunService.Heartbeat:Connect(function()
            if dragging and dragStart then
                local delta = UserInputService:GetMouseLocation() - Vector2.new(dragStart.X, dragStart.Y)
                win.Position = UDim2.fromOffset(startPos.X.Offset + delta.X, startPos.Y.Offset + delta.Y)
            end
        end)
    end

    -- ── Sidebar ────────────────────────────────────────────────
    local sidebar = frame(win, {
        Name             = "Sidebar",
        Size             = UDim2.new(0, sideW, 1, -36),
        Position         = UDim2.new(0, 0, 0, 36),
        BackgroundColor3 = Theme.Sidebar,
        ZIndex           = win.ZIndex + 1,
        ClipsDescendants = true,
    })
    -- Round bottom-left corner only
    local sideCorner = Instance.new("UICorner")
    sideCorner.CornerRadius = UDim.new(0, 10)
    sideCorner.Parent = sidebar
    -- Fix top corners of sidebar
    frame(sidebar, {
        Size             = UDim2.new(1, 0, 0, 10),
        BackgroundColor3 = Theme.Sidebar,
        ZIndex           = sidebar.ZIndex,
    })
    -- Fix right corner (top-right and bottom-right of sidebar are square)
    frame(sidebar, {
        Size             = UDim2.new(0, 10, 1, 0),
        Position         = UDim2.new(1, -10, 0, 0),
        BackgroundColor3 = Theme.Sidebar,
        ZIndex           = sidebar.ZIndex,
    })

    -- Sidebar right border
    frame(sidebar, {
        Size             = UDim2.new(0, 1, 1, 0),
        Position         = UDim2.new(1, -1, 0, 0),
        BackgroundColor3 = Theme.SidebarBorder,
        ZIndex           = sidebar.ZIndex + 1,
    })

    -- Sidebar nav list
    local navList = frame(sidebar, {
        Name             = "NavList",
        Size             = UDim2.new(1, 0, 1, -10),
        Position         = UDim2.new(0, 0, 0, 10),
        BackgroundTransparency = 1,
        ZIndex           = sidebar.ZIndex + 1,
    })
    local navLayout = Instance.new("UIListLayout")
    navLayout.SortOrder      = Enum.SortOrder.LayoutOrder
    navLayout.Padding        = UDim.new(0, 2)
    navLayout.Parent         = navList

    local navPadding = Instance.new("UIPadding")
    navPadding.PaddingLeft   = UDim.new(0, 8)
    navPadding.PaddingRight  = UDim.new(0, 8)
    navPadding.PaddingTop    = UDim.new(0, 6)
    navPadding.Parent        = navList

    -- Sidebar bottom info
    local sideBottom = frame(sidebar, {
        Size             = UDim2.new(1, 0, 0, 30),
        Position         = UDim2.new(0, 0, 1, -30),
        BackgroundColor3 = Theme.Sidebar,
        ZIndex           = sidebar.ZIndex + 2,
    })
    label(sideBottom, {
        Text      = "⚡ VIOLET THUNDER",
        Size      = UDim2.new(1, -10, 1, 0),
        Position  = UDim2.new(0, 8, 0, 0),
        TextColor3 = Theme.TextMuted,
        TextSize  = 9,
        ZIndex    = sideBottom.ZIndex + 1,
    })

    -- ── Content Area ───────────────────────────────────────────
    local contentArea = frame(win, {
        Name             = "ContentArea",
        Size             = UDim2.new(1, -sideW, 1, -36),
        Position         = UDim2.new(0, sideW, 0, 36),
        BackgroundColor3 = Theme.Content,
        ZIndex           = win.ZIndex + 1,
        ClipsDescendants = true,
    })
    -- Round bottom-right
    local contentCorner = Instance.new("UICorner")
    contentCorner.CornerRadius = UDim.new(0, 10)
    contentCorner.Parent = contentArea
    -- Fix left + top corners of content
    frame(contentArea, {
        Size             = UDim2.new(0, 10, 1, 0),
        BackgroundColor3 = Theme.Content,
        ZIndex           = contentArea.ZIndex,
    })
    frame(contentArea, {
        Size             = UDim2.new(1, 0, 0, 10),
        BackgroundColor3 = Theme.Content,
        ZIndex           = contentArea.ZIndex,
    })

    -- ── Window API ─────────────────────────────────────────────
    local windowAPI  = {}
    local activeNav  = nil
    local tabPages   = {}

    function windowAPI:AddTab(tabName, icon)
        tabName = tostring(tabName or "Tab")
        icon    = icon or "•"

        -- Nav button in sidebar
        local navBtn = button(navList, {
            Name             = "NavBtn_" .. tabName,
            Size             = UDim2.new(1, 0, 0, 32),
            BackgroundColor3 = Theme.ElementBg,
            BackgroundTransparency = 1,
            TextColor3       = Theme.TextMuted,
            TextSize         = 12,
            Text             = "",
            ZIndex           = navList.ZIndex + 1,
        })
        corner(navBtn, 7)

        -- Nav icon
        label(navBtn, {
            Text      = icon,
            Size      = UDim2.fromOffset(20, 32),
            Position  = UDim2.new(0, 6, 0, 0),
            TextColor3 = Theme.TextMuted,
            TextSize  = 14,
            TextXAlignment = Enum.TextXAlignment.Center,
            ZIndex    = navBtn.ZIndex + 1,
        })

        -- Nav label
        local navLabel = label(navBtn, {
            Text      = string.upper(tabName),
            Size      = UDim2.new(1, -34, 1, 0),
            Position  = UDim2.new(0, 30, 0, 0),
            TextColor3 = Theme.TextMuted,
            TextSize  = 11,
            ZIndex    = navBtn.ZIndex + 1,
        })

        -- Active indicator bar (left side)
        local activeBar = frame(navBtn, {
            Size             = UDim2.fromOffset(3, 16),
            Position         = UDim2.new(0, -8, 0.5, -8),
            BackgroundColor3 = Theme.AccentLight,
            BackgroundTransparency = 1,
            ZIndex           = navBtn.ZIndex + 2,
        })
        corner(activeBar, 2)

        -- Content page
        local page = frame(contentArea, {
            Name             = "Page_" .. tabName,
            Size             = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible          = false,
            ZIndex           = contentArea.ZIndex + 1,
            ClipsDescendants = true,
        })

        -- Page scroller
        local scroller = Instance.new("ScrollingFrame")
        scroller.Name                        = "Scroller"
        scroller.Parent                      = page
        scroller.Size                        = UDim2.new(1, 0, 1, 0)
        scroller.BackgroundTransparency      = 1
        scroller.BorderSizePixel             = 0
        scroller.ScrollBarThickness          = 3
        scroller.ScrollBarImageColor3        = Theme.AccentLight
        scroller.ScrollBarImageTransparency  = 0.3
        scroller.CanvasSize                  = UDim2.new(0, 0, 0, 0)
        scroller.ZIndex                      = page.ZIndex

        local pageLayout = Instance.new("UIListLayout")
        pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        pageLayout.Padding   = UDim.new(0, 6)
        pageLayout.Parent    = scroller

        local pagePad = Instance.new("UIPadding")
        pagePad.PaddingLeft   = UDim.new(0, 12)
        pagePad.PaddingRight  = UDim.new(0, 12)
        pagePad.PaddingTop    = UDim.new(0, 12)
        pagePad.PaddingBottom = UDim.new(0, 12)
        pagePad.Parent        = scroller

        pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scroller.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 24)
        end)

        table.insert(tabPages, {btn = navBtn, page = page, bar = activeBar, lbl = navLabel})

        local function selectThis()
            -- Deselect all
            for _, t in ipairs(tabPages) do
                t.page.Visible = false
                tween(t.btn, {BackgroundTransparency = 1}, 0.12)
                tween(t.lbl, {TextColor3 = Theme.TextMuted}, 0.12)
                tween(t.bar, {BackgroundTransparency = 1}, 0.12)
            end
            -- Select this
            page.Visible = true
            tween(navBtn, {BackgroundTransparency = 0.5}, 0.12)
            navBtn.BackgroundColor3 = Theme.ElementHover
            tween(navLabel, {TextColor3 = Theme.AccentLight}, 0.12)
            tween(activeBar, {BackgroundTransparency = 0}, 0.12)
            activeNav = navBtn
        end

        navBtn.MouseButton1Click:Connect(selectThis)
        navBtn.MouseEnter:Connect(function()
            if activeNav ~= navBtn then
                tween(navBtn, {BackgroundTransparency = 0.8}, 0.1)
                navBtn.BackgroundColor3 = Theme.ElementHover
            end
        end)
        navBtn.MouseLeave:Connect(function()
            if activeNav ~= navBtn then
                tween(navBtn, {BackgroundTransparency = 1}, 0.1)
            end
        end)

        -- Auto-select first tab
        if #tabPages == 1 then
            selectThis()
        end

        -- ── Tab API ──────────────────────────────────────────
        local tabAPI = {}

        -- Section header helper
        function tabAPI:AddSection(sectionName)
            local sec = frame(scroller, {
                Size             = UDim2.new(1, 0, 0, 22),
                BackgroundTransparency = 1,
                ZIndex           = scroller.ZIndex + 1,
            })
            label(sec, {
                Text      = string.upper(sectionName or "Section"),
                Size      = UDim2.new(1, 0, 1, 0),
                TextColor3 = Theme.AccentLight,
                TextSize  = 10,
                ZIndex    = sec.ZIndex + 1,
            })
            -- Divider line
            frame(sec, {
                Size             = UDim2.new(1, 0, 0, 1),
                Position         = UDim2.new(0, 0, 1, -1),
                BackgroundColor3 = Theme.SidebarBorder,
                ZIndex           = sec.ZIndex + 1,
            })
            return sec
        end

        -- Label
        function tabAPI:AddLabel(text)
            local lbl = frame(scroller, {
                Size             = UDim2.new(1, 0, 0, 28),
                BackgroundColor3 = Theme.ElementBg,
                ZIndex           = scroller.ZIndex + 1,
            })
            corner(lbl, 6)
            label(lbl, {
                Text      = tostring(text or "Label"),
                Size      = UDim2.new(1, -16, 1, 0),
                Position  = UDim2.new(0, 12, 0, 0),
                TextColor3 = Theme.TextSecondary,
                TextSize  = 12,
                ZIndex    = lbl.ZIndex + 1,
            })
            return lbl
        end

        -- Button
        function tabAPI:AddButton(btnLabel, callback)
            btnLabel = tostring(btnLabel or "Button")
            callback = type(callback) == "function" and callback or function() end

            local el = frame(scroller, {
                Size             = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = Theme.ElementBg,
                ZIndex           = scroller.ZIndex + 1,
            })
            corner(el, 7)
            stroke(el, Theme.ElementBorder, 1, 0.6)

            local btnText = label(el, {
                Text      = string.upper(btnLabel),
                Size      = UDim2.new(1, -40, 1, 0),
                Position  = UDim2.new(0, 12, 0, 0),
                TextColor3 = Theme.TextPrimary,
                TextSize  = 12,
                ZIndex    = el.ZIndex + 1,
            })

            -- Arrow indicator
            label(el, {
                Text      = "›",
                Size      = UDim2.fromOffset(20, 32),
                Position  = UDim2.new(1, -24, 0, 0),
                TextColor3 = Theme.AccentLight,
                TextSize  = 16,
                TextXAlignment = Enum.TextXAlignment.Center,
                ZIndex    = el.ZIndex + 1,
            })

            local clickBtn = button(el, {
                Size  = UDim2.new(1, 0, 1, 0),
                ZIndex = el.ZIndex + 2,
                Text  = "",
            })

            clickBtn.MouseEnter:Connect(function()
                tween(el, {BackgroundColor3 = Theme.ElementHover}, 0.1)
            end)
            clickBtn.MouseLeave:Connect(function()
                tween(el, {BackgroundColor3 = Theme.ElementBg}, 0.1)
            end)
            clickBtn.MouseButton1Click:Connect(function()
                tween(el, {BackgroundColor3 = Theme.Accent}, 0.08)
                task.delay(0.12, function()
                    tween(el, {BackgroundColor3 = Theme.ElementBg}, 0.15)
                end)
                pcall(callback)
            end)

            return el
        end

        -- Toggle / Switch
        function tabAPI:AddToggle(toggleLabel, default, callback)
            toggleLabel = tostring(toggleLabel or "Toggle")
            callback    = type(callback) == "function" and callback or function() end
            local state = default == true

            local el = frame(scroller, {
                Size             = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = Theme.ElementBg,
                ZIndex           = scroller.ZIndex + 1,
            })
            corner(el, 7)
            stroke(el, Theme.ElementBorder, 1, 0.6)

            label(el, {
                Text      = string.upper(toggleLabel),
                Size      = UDim2.new(1, -60, 1, 0),
                Position  = UDim2.new(0, 12, 0, 0),
                TextColor3 = Theme.TextPrimary,
                TextSize  = 12,
                ZIndex    = el.ZIndex + 1,
            })

            -- Toggle track
            local track = frame(el, {
                Size             = UDim2.fromOffset(36, 20),
                Position         = UDim2.new(1, -46, 0.5, -10),
                BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff,
                ZIndex           = el.ZIndex + 2,
            })
            corner(track, 10)
            stroke(track, Theme.ElementBorder, 1, 0.3)

            -- Toggle thumb
            local thumb = frame(track, {
                Size             = UDim2.fromOffset(14, 14),
                Position         = state and UDim2.fromOffset(19, 3) or UDim2.fromOffset(3, 3),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                ZIndex           = track.ZIndex + 1,
            })
            corner(thumb, 7)

            local function updateVisual()
                tween(track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.15)
                tween(thumb, {Position = state and UDim2.fromOffset(19, 3) or UDim2.fromOffset(3, 3)}, 0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
            end

            local clickBtn = button(el, {
