--// MINIMIZER
function Library:CreateMinimizer(cfg)
    cfg = cfg or {}
    if self._mini and self._mini.Parent then return self._mini end

    local miniGui = Instance.new("ScreenGui")
    miniGui.Name           = "VTMiniGui"
    miniGui.DisplayOrder   = 1001
    miniGui.ResetOnSpawn   = false
    miniGui.IgnoreGuiInset = true
    miniGui.Parent         = game:GetService("CoreGui")

    local holder = frame(miniGui, {
        Size     = cfg.Size or UDim2.fromOffset(38, 38),
        Position = cfg.Position or UDim2.fromOffset(20, 20),
        BackgroundTransparency = 1,
        ZIndex   = 100,
    })

    local btn = button(holder, {
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Theme.Sidebar,
        BackgroundTransparency = 0,
        ZIndex           = 101,
        Text             = "⚡",
        TextSize         = 16,
        TextColor3       = Theme.AccentLight,
        TextXAlignment   = Enum.TextXAlignment.Center,
    })
    corner(btn, 8)
    local miniStroke = stroke(btn, Theme.AccentLight, 1.5, 0.3)
    animateBorder(miniStroke)

    btn.MouseButton1Click:Connect(function()
        Root.Enabled = not Root.Enabled
        tween(btn, {Size = UDim2.fromOffset(30, 30)}, 0.08)
        task.delay(0.08, function()
            tween(btn, {Size = UDim2.new(1,0,1,0)}, 0.12, Enum.EasingStyle.Back)
        end)
    end)

    -- Drag
    if cfg.Draggable ~= false then
        local dragging, dragStart, startPos = false, nil, nil
        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                dragStart = UserInputService:GetMouseLocation()
                startPos  = holder.Position
            end
        end)
        btn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        RunService.Heartbeat:Connect(function()
            if dragging and dragStart then
                local delta = UserInputService:GetMouseLocation() - dragStart
                if delta.Magnitude > 4 then
                    holder.Position = UDim2.fromOffset(startPos.X.Offset + delta.X, startPos.Y.Offset + delta.Y)
                end
            end
        end)
    end

    self._mini = holder
    return holder
end

return Library
