                Position  = UDim2.new(0, 12, 0, 0),
                TextColor3 = Theme.TextPrimary,
                TextSize  = 12,
                ZIndex    = el.ZIndex + 1,
            })

            local keyName = currentKey ~= Enum.KeyCode.Unknown and currentKey.Name or "NONE"
            local keyBtn = button(el, {
                Text             = keyName,
                Size             = UDim2.new(0, 70, 0, 22),
                Position         = UDim2.new(1, -82, 0.5, -11),
