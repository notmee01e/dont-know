            corner(el, 7)
            stroke(el, Theme.ElementBorder, 1, 0.6)

            label(el, {
                Text      = string.upper(dropLabel),
                Size      = UDim2.new(0.55, 0, 1, 0),
                Position  = UDim2.new(0, 12, 0, 0),
                TextColor3 = Theme.TextPrimary,
                TextSize  = 12,
                ZIndex    = el.ZIndex + 1,
            })

            local selectedLabel = label(el, {
                Text      = items[1] and string.upper(items[1]) or "SELECT...",
                Size      = UDim2.new(0.4, -30, 1, 0),
                Position  = UDim2.new(0.55, 0, 0, 0),
                TextColor3 = Theme.AccentLight,
                TextSize  = 11,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex    = el.ZIndex + 1,
            })

            -- Arrow
            local arrow = label(el, {
                Text      = "⌄",
                Size      = UDim2.fromOffset(20, 32),
                Position  = UDim2.new(1, -22, 0, 0),
                TextColor3 = Theme.AccentLight,
                TextSize  = 14,
                TextXAlignment = Enum.TextXAlignment.Center,
                ZIndex    = el.ZIndex + 1,
            })

            -- Dropdown list
            local dropList = frame(el, {
                Name             = "DropList",
                Size             = UDim2.new(1, 0, 0, 0),
                Position         = UDim2.new(0, 0, 1, 4),
                BackgroundColor3 = Theme.ContentAlt,
                ZIndex           = el.ZIndex + 10,
                ClipsDescendants = true,
                Visible          = false,
            })
            corner(dropList, 7)
            stroke(dropList, Theme.ElementBorder, 1, 0.4)

            local dropLayout = Instance.new("UIListLayout")
            dropLayout.SortOrder = Enum.SortOrder.LayoutOrder
            dropLayout.Parent    = dropList

            local dropPad = Instance.new("UIPadding")
            dropPad.PaddingTop    = UDim.new(0, 4)
            dropPad.PaddingBottom = UDim.new(0, 4)
            dropPad.Parent        = dropList

            local isOpen = false
            local selectedValue = items[1]

            local function buildItems()
                for _, c in ipairs(dropList:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                for _, item in ipairs(items) do
                    local itemBtn = button(dropList, {
                        Text             = "  " .. string.upper(tostring(item)),
                        Size             = UDim2.new(1, 0, 0, 28),
                        BackgroundColor3 = Theme.ContentAlt,
                        BackgroundTransparency = 0,
                        TextColor3       = item == selectedValue and Theme.AccentLight or Theme.TextSecondary,
                        TextSize         = 11,
                        ZIndex           = dropList.ZIndex + 1,
                    })
                    itemBtn.MouseEnter:Connect(function()
                        tween(itemBtn, {BackgroundColor3 = Theme.ElementHover, TextColor3 = Theme.TextPrimary}, 0.08)
                    end)
                    itemBtn.MouseLeave:Connect(function()
                        tween(itemBtn, {BackgroundColor3 = Theme.ContentAlt, TextColor3 = item == selectedValue and Theme.AccentLight or Theme.TextSecondary}, 0.08)
                    end)
                    itemBtn.MouseButton1Click:Connect(function()
                        selectedValue = item
                        selectedLabel.Text = string.upper(tostring(item))
                        isOpen = false
                        tween(dropList, {Size = UDim2.new(1, 0, 0, 0)}, 0.15)
                        task.delay(0.15, function() dropList.Visible = false end)
                        tween(arrow, {Rotation = 0}, 0.15)
                        buildItems()
                        pcall(callback, item)
                    end)
                end
            end
            buildItems()

            local headerBtn = button(el, {
                Size  = UDim2.new(1, 0, 1, 0),
                ZIndex = el.ZIndex + 2,
                Text  = "",
            })
            headerBtn.MouseEnter:Connect(function()
                tween(el, {BackgroundColor3 = Theme.ElementHover}, 0.1)
            end)
            headerBtn.MouseLeave:Connect(function()
                tween(el, {BackgroundColor3 = Theme.ElementBg}, 0.1)
            end)
            headerBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    dropList.Visible = true
                    local itemCount = #items
                    local listH = math.min(itemCount * 28 + 8, 150)
                    tween(dropList, {Size = UDim2.new(1, 0, 0, listH)}, 0.15)
                    tween(arrow, {Rotation = 180}, 0.15)
                else
                    tween(dropList, {Size = UDim2.new(1, 0, 0, 0)}, 0.15)
                    task.delay(0.15, function() dropList.Visible = false end)
                    tween(arrow, {Rotation = 0}, 0.15)
                end
            end)

            local ddAPI = {}
            function ddAPI:Set(val)
                selectedValue = val
                selectedLabel.Text = string.upper(tostring(val))
                buildItems()
            end
            function ddAPI:Get() return selectedValue end
            function ddAPI:SetItems(newItems)
                items = newItems
                buildItems()
            end
            return ddAPI, el
        end

