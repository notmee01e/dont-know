local Library = {}

function Library:AddWindow(title, opts)
    windowCount = windowCount + 1
    opts  = opts  or {}
    title = tostring(title or "Violet Thunder")
    local winW  = opts.width  or 580
    local winH  = opts.height or 380
    local sideW = 148

    local win = mkFrame(Root, {
        Name=("Win"..windowCount), Size=UDim2.fromOffset(winW,winH),
        Position=UDim2.fromOffset(80+(windowCount-1)*28, 80+(windowCount-1)*28),
        BackgroundColor3=T.WinBg, ZIndex=windowCount*10, ClipsDescendants=false,
    })
    mkCorner(win,10); animBorder(mkStroke(win,T.WinBorder,1.5,0.3))

    mkImg(win, {Size=UDim2.new(1,40,1,40), Position=UDim2.new(0,-20,0,-20), ZIndex=win.ZIndex-1,
        Image="rbxassetid://6014261993", ImageColor3=Color3.new(0,0,0), ImageTransparency=0.55,
        ScaleType=Enum.ScaleType.Slice, SliceCenter=Rect.new(49,49,450,450)})

    local bar = mkFrame(win, {Size=UDim2.new(1,0,0,36), BackgroundColor3=T.TitleBar, ZIndex=win.ZIndex+1})
    mkCorner(bar,10)
    mkFrame(bar, {Size=UDim2.new(1,0,0.5,0), Position=UDim2.new(0,0,0.5,0), BackgroundColor3=T.TitleBar, ZIndex=bar.ZIndex})
    mkFrame(bar, {Size=UDim2.new(1,0,0,1),   Position=UDim2.new(0,0,1,-1),  BackgroundColor3=T.SideBar2, ZIndex=bar.ZIndex+1})

    local dot = mkFrame(bar, {Size=UDim2.fromOffset(8,8), Position=UDim2.new(0,14,0.5,-4), BackgroundColor3=T.AccentLight, ZIndex=bar.ZIndex+2})
    mkCorner(dot,4)
    task.spawn(function()
        while dot and dot.Parent do
            tw(dot,{BackgroundColor3=T.Accent},1,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut); task.wait(1)
            tw(dot,{BackgroundColor3=T.AccentLight},1,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut); task.wait(1)
        end
    end)

    mkLabel(bar, {Text=string.upper(title), Size=UDim2.new(1,-110,1,0), Position=UDim2.new(0,30,0,0), TextColor3=T.TextPri, TextSize=12, ZIndex=bar.ZIndex+2})

    local closeBtn = mkBtn(bar, {Text="✕", Size=UDim2.fromOffset(28,28), Position=UDim2.new(1,-34,0.5,-14),
        BackgroundColor3=Color3.fromRGB(180,40,80), BackgroundTransparency=1, TextColor3=T.TextMut, TextSize=13, ZIndex=bar.ZIndex+3})
    mkCorner(closeBtn,6)
    closeBtn.MouseEnter:Connect(function() tw(closeBtn,{BackgroundTransparency=0.2,TextColor3=T.TextPri},0.1) end)
    closeBtn.MouseLeave:Connect(function() tw(closeBtn,{BackgroundTransparency=1,TextColor3=T.TextMut},0.1) end)
    closeBtn.MouseButton1Click:Connect(function() Root.Enabled=false end)

    local minBtn = mkBtn(bar, {Text="─", Size=UDim2.fromOffset(28,28), Position=UDim2.new(1,-66,0.5,-14),
        BackgroundTransparency=1, TextColor3=T.TextMut, TextSize=13, ZIndex=bar.ZIndex+3})
    mkCorner(minBtn,6)
    local minimized, savedH = false, winH
    minBtn.MouseEnter:Connect(function() minBtn.BackgroundColor3=T.ElBg; tw(minBtn,{BackgroundTransparency=0.7,TextColor3=T.TextSec},0.1) end)
    minBtn.MouseLeave:Connect(function() tw(minBtn,{BackgroundTransparency=1,TextColor3=T.TextMut},0.1) end)
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then savedH=win.AbsoluteSize.Y; tw(win,{Size=UDim2.fromOffset(win.AbsoluteSize.X,36)},0.2)
        else tw(win,{Size=UDim2.fromOffset(win.AbsoluteSize.X,savedH)},0.2,Enum.EasingStyle.Back,Enum.EasingDirection.Out) end
    end)

    local drag, ds, sp = false, nil, nil
    bar.InputBegan:Connect(function(i)  if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true; ds=i.Position; sp=win.Position end end)
    bar.InputEnded:Connect(function(i)  if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    RunService.Heartbeat:Connect(function()
        if drag and ds then
            local d = UserInputService:GetMouseLocation()-Vector2.new(ds.X,ds.Y)
            win.Position = UDim2.fromOffset(sp.X.Offset+d.X, sp.Y.Offset+d.Y)
        end
    end)

    local sb = mkFrame(win, {Size=UDim2.new(0,sideW,1,-36), Position=UDim2.new(0,0,0,36), BackgroundColor3=T.Sidebar, ZIndex=win.ZIndex+1, ClipsDescendants=true})
    mkCorner(sb,10)
    mkFrame(sb, {Size=UDim2.new(1,0,0,10),  BackgroundColor3=T.Sidebar, ZIndex=sb.ZIndex})
    mkFrame(sb, {Size=UDim2.new(0,10,1,0),  Position=UDim2.new(1,-10,0,0), BackgroundColor3=T.Sidebar, ZIndex=sb.ZIndex})
    mkFrame(sb, {Size=UDim2.new(0,1,1,0),   Position=UDim2.new(1,-1,0,0),  BackgroundColor3=T.SideBar2, ZIndex=sb.ZIndex+1})

    local navList = mkFrame(sb, {Size=UDim2.new(1,0,1,-30), Position=UDim2.new(0,0,0,10), BackgroundTransparency=1, ZIndex=sb.ZIndex+1})
    local navLay  = Instance.new("UIListLayout"); navLay.SortOrder=Enum.SortOrder.LayoutOrder; navLay.Padding=UDim.new(0,2); navLay.Parent=navList
    local navPad  = Instance.new("UIPadding");  navPad.PaddingLeft=UDim.new(0,7); navPad.PaddingRight=UDim.new(0,7); navPad.PaddingTop=UDim.new(0,5); navPad.Parent=navList

    local sbBot = mkFrame(sb, {Size=UDim2.new(1,0,0,22), Position=UDim2.new(0,0,1,-22), BackgroundColor3=T.Sidebar, ZIndex=sb.ZIndex+2})
    mkLabel(sbBot, {Text="⚡ VIOLET THUNDER", Size=UDim2.new(1,-8,1,0), Position=UDim2.new(0,8,0,0), TextColor3=T.TextMut, TextSize=8, ZIndex=sbBot.ZIndex+1})

    local ca = mkFrame(win, {Size=UDim2.new(1,-sideW,1,-36), Position=UDim2.new(0,sideW,0,36), BackgroundColor3=T.Content, ZIndex=win.ZIndex+1, ClipsDescendants=true})
    mkCorner(ca,10)
    mkFrame(ca, {Size=UDim2.new(0,10,1,0), BackgroundColor3=T.Content, ZIndex=ca.ZIndex})
    mkFrame(ca, {Size=UDim2.new(1,0,0,10), BackgroundColor3=T.Content, ZIndex=ca.ZIndex})

    local windowAPI = {}
    local activeNav = nil
    local tabPages  = {}

    function windowAPI:AddTab(tabName, icon)
        tabName = tostring(tabName or "Tab"); icon = icon or "•"

        local navBtn = mkBtn(navList, {Size=UDim2.new(1,0,0,30), BackgroundColor3=T.ElBg, BackgroundTransparency=1, Text="", ZIndex=navList.ZIndex+1})
        mkCorner(navBtn,6)
        mkLabel(navBtn, {Text=icon, Size=UDim2.fromOffset(20,30), Position=UDim2.new(0,5,0,0), TextColor3=T.TextMut, TextSize=13, TextXAlignment=Enum.TextXAlignment.Center, ZIndex=navBtn.ZIndex+1})
        local navLbl = mkLabel(navBtn, {Text=string.upper(tabName), Size=UDim2.new(1,-32,1,0), Position=UDim2.new(0,28,0,0), TextColor3=T.TextMut, TextSize=10, ZIndex=navBtn.ZIndex+1})
        local actBar = mkFrame(navBtn, {Size=UDim2.fromOffset(3,14), Position=UDim2.new(0,-7,0.5,-7), BackgroundColor3=T.AccentLight, BackgroundTransparency=1, ZIndex=navBtn.ZIndex+2})
        mkCorner(actBar,2)

        local page = mkFrame(ca, {Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Visible=false, ZIndex=ca.ZIndex+1, ClipsDescendants=true})

        local scroller = Instance.new("ScrollingFrame")
        scroller.Parent=page; scroller.Size=UDim2.new(1,0,1,0); scroller.BackgroundTransparency=1
        scroller.BorderSizePixel=0; scroller.ScrollBarThickness=3
        scroller.ScrollBarImageColor3=T.AccentLight; scroller.ScrollBarImageTransparency=0.3
        scroller.CanvasSize=UDim2.new(0,0,0,0); scroller.ZIndex=page.ZIndex

        local pgLay = Instance.new("UIListLayout"); pgLay.SortOrder=Enum.SortOrder.LayoutOrder; pgLay.Padding=UDim.new(0,5); pgLay.Parent=scroller
        local pgPad = Instance.new("UIPadding"); pgPad.PaddingLeft=UDim.new(0,10); pgPad.PaddingRight=UDim.new(0,10); pgPad.PaddingTop=UDim.new(0,10); pgPad.PaddingBottom=UDim.new(0,10); pgPad.Parent=scroller
        pgLay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scroller.CanvasSize = UDim2.new(0,0,0, pgLay.AbsoluteContentSize.Y+20)
        end)

        table.insert(tabPages, {btn=navBtn, page=page, bar=actBar, lbl=navLbl})

        local function selectThis()
            for _,t in ipairs(tabPages) do
                t.page.Visible=false
                tw(t.btn,{BackgroundTransparency=1},0.12)
                tw(t.lbl,{TextColor3=T.TextMut},0.12)
                tw(t.bar,{BackgroundTransparency=1},0.12)
            end
            page.Visible=true
            navBtn.BackgroundColor3=T.ElHover
            tw(navBtn,{BackgroundTransparency=0.5},0.12)
            tw(navLbl,{TextColor3=T.AccentLight},0.12)
            tw(actBar,{BackgroundTransparency=0},0.12)
            activeNav=navBtn
        end

        navBtn.MouseButton1Click:Connect(selectThis)
        navBtn.MouseEnter:Connect(function() if activeNav~=navBtn then navBtn.BackgroundColor3=T.ElHover; tw(navBtn,{BackgroundTransparency=0.8},0.1) end end)
        navBtn.MouseLeave:Connect(function() if activeNav~=navBtn then tw(navBtn,{BackgroundTransparency=1},0.1) end end)
        if #tabPages==1 then selectThis() end

        -- use module-level buildAPI
        local tabAPI = buildAPI(scroller, ca.ZIndex+2)
        function tabAPI:Show() selectThis() end
        return tabAPI, page
    end

    function windowAPI:Notify(t, msg, dur)
        dur = dur or 3
        local n = mkFrame(Root, {Size=UDim2.fromOffset(248,52), Position=UDim2.new(1,10,1,-74), BackgroundColor3=T.ContentAlt, ZIndex=9999})
        mkCorner(n,8); mkStroke(n,T.AccentLight,1.5,0.3)
        mkFrame(n, {Size=UDim2.fromOffset(3,52), BackgroundColor3=T.AccentLight, ZIndex=n.ZIndex+1})
        mkLabel(n, {Text=string.upper(tostring(t)), Size=UDim2.new(1,-16,0,18), Position=UDim2.new(0,10,0,6), TextColor3=T.AccentLight, TextSize=10, ZIndex=n.ZIndex+2})
        mkLabel(n, {Text=tostring(msg), Size=UDim2.new(1,-16,0,16), Position=UDim2.new(0,10,0,24), TextColor3=T.TextSec, TextSize=9, TextWrapped=true, ZIndex=n.ZIndex+2})
        tw(n, {Position=UDim2.new(1,-264,1,-74)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        task.delay(dur, function() tw(n,{Position=UDim2.new(1,10,1,-74)},0.25); task.delay(0.25,function() n:Destroy() end) end)
    end

    return windowAPI, win
end

function Library:CreateMinimizer(cfg)
    cfg = cfg or {}
    if self._mini and self._mini.Parent then return self._mini end
    local mg = Instance.new("ScreenGui"); mg.Name="VTMiniGui"; mg.DisplayOrder=1001; mg.ResetOnSpawn=false; mg.IgnoreGuiInset=true; mg.Parent=game:GetService("CoreGui")
    local holder = mkFrame(mg, {Size=cfg.Size or UDim2.fromOffset(38,38), Position=cfg.Position or UDim2.fromOffset(20,20), BackgroundTransparency=1, ZIndex=100})
    local icon = cfg.Icon or ""; local isId = type(icon)=="string" and icon:match("^rbxassetid://")
    local btn = mkBtn(holder, {Size=UDim2.new(1,0,1,0), BackgroundColor3=T.Sidebar, BackgroundTransparency=0, ZIndex=101, Text=isId and "" or "⚡", TextSize=16, TextColor3=T.AccentLight, TextXAlignment=Enum.TextXAlignment.Center})
    mkCorner(btn, cfg.Corner or 8); animBorder(mkStroke(btn,T.AccentLight,1.5,0.3))
    if isId then mkImg(btn, {Size=UDim2.new(0.68,0,0.68,0), Position=UDim2.new(0.16,0,0.16,0), Image=icon, ImageColor3=T.AccentLight, ZIndex=btn.ZIndex+1}) end
    btn.MouseButton1Click:Connect(function()
        Root.Enabled = not Root.Enabled
        tw(holder,{Size=UDim2.fromOffset(30,30)},0.08)
        task.delay(0.08, function() tw(holder,{Size=cfg.Size or UDim2.fromOffset(38,38)},0.12,Enum.EasingStyle.Back) end)
    end)
    if cfg.Draggable~=false then
        local drg,ds,sp=false,nil,nil
        btn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drg=true; ds=UserInputService:GetMouseLocation(); sp=holder.Position end end)
        btn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drg=false end end)
        RunService.Heartbeat:Connect(function()
            if drg and ds then local d=UserInputService:GetMouseLocation()-ds; holder.Position=UDim2.fromOffset(sp.X.Offset+d.X,sp.Y.Offset+d.Y) end
        end)
    end
    self._mini = holder; return holder
end

return Library
