local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")
local RunService       = game:GetService("RunService")

do
    local e = game:GetService("CoreGui"):FindFirstChild("VioletThunderUI")
    if e then e:Destroy() end
end

local Root = Instance.new("ScreenGui")
Root.Name           = "VioletThunderUI"
Root.ResetOnSpawn   = false
Root.IgnoreGuiInset = true
Root.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
Root.Parent         = game:GetService("CoreGui")

local T = {
    Sidebar     = Color3.fromRGB(18,  8,  36),
    SideBar2    = Color3.fromRGB(60,  20, 110),
    Content     = Color3.fromRGB(22,  10,  44),
    ContentAlt  = Color3.fromRGB(28,  13,  54),
    TitleBar    = Color3.fromRGB(14,   6,  28),
    Accent      = Color3.fromRGB(138, 43, 226),
    AccentLight = Color3.fromRGB(180, 90, 255),
    AccentDark  = Color3.fromRGB(90,  20, 180),
    TextPri     = Color3.fromRGB(255,255,255),
    TextSec     = Color3.fromRGB(180,150,220),
    TextMut     = Color3.fromRGB(120, 90, 160),
    ElBg        = Color3.fromRGB(32,  15,  62),
    ElBorder    = Color3.fromRGB(75,  30, 140),
    ElHover     = Color3.fromRGB(50,  20,  95),
    TogOff      = Color3.fromRGB(45,  20,  80),
    TogOn       = Color3.fromRGB(138, 43, 226),
    WinBg       = Color3.fromRGB(12,   5,  24),
    WinBorder   = Color3.fromRGB(55,  18, 100),
    FolderBg    = Color3.fromRGB(20,   9,  40),
    FolderHead  = Color3.fromRGB(35,  15,  70),
}

local bindingActive = false
local windowCount   = 0

-- ── helpers ─────────────────────────────────────────────────────
local function tw(obj, props, t, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(t or 0.15, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props):Play()
end

local function mkCorner(p, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 6); c.Parent = p; return c
end

local function mkStroke(p, col, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color = col or T.ElBorder; s.Thickness = thick or 1; s.Transparency = trans or 0; s.Parent = p; return s
end

local function mkFrame(parent, props)
    local f = Instance.new("Frame"); f.BackgroundTransparency = 0; f.BorderSizePixel = 0
    for k,v in pairs(props or {}) do f[k] = v end; f.Parent = parent; return f
end

local function mkLabel(parent, props)
    local l = Instance.new("TextLabel"); l.BackgroundTransparency = 1; l.BorderSizePixel = 0
    l.Font = Enum.Font.GothamBold; l.TextSize = 12; l.TextColor3 = T.TextPri
    l.TextXAlignment = Enum.TextXAlignment.Left
    for k,v in pairs(props or {}) do l[k] = v end; l.Parent = parent; return l
end

local function mkBtn(parent, props)
    local b = Instance.new("TextButton"); b.BackgroundTransparency = 1; b.BorderSizePixel = 0
    b.AutoButtonColor = false; b.Font = Enum.Font.GothamBold; b.TextSize = 12; b.TextColor3 = T.TextPri
    for k,v in pairs(props or {}) do b[k] = v end; b.Parent = parent; return b
end

local function mkImg(parent, props)
    local i = Instance.new("ImageLabel"); i.BackgroundTransparency = 1; i.BorderSizePixel = 0
    for k,v in pairs(props or {}) do i[k] = v end; i.Parent = parent; return i
end

local function animBorder(s)
    local cols = {Color3.fromRGB(180,80,255), Color3.fromRGB(120,40,220), Color3.fromRGB(210,120,255), Color3.fromRGB(90,20,180)}
    local i = 1
    task.spawn(function()
        while s and s.Parent do
            i = (i % #cols) + 1
            tw(s, {Color=cols[i], Transparency=0}, 1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut); task.wait(1.4)
            tw(s, {Color=T.WinBorder, Transparency=0.5}, 1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut); task.wait(1.4)
        end
    end)
end

UserInputService.InputBegan:Connect(function(input, gp)
    if input.KeyCode == Enum.KeyCode.RightShift and not bindingActive and not gp then
        Root.Enabled = not Root.Enabled
    end
end)

-- ══════════════════════════════════════════════════════════════
--  buildAPI  ← MODULE LEVEL (forward declared so AddFolder
--              can call it recursively without scope issues)
-- ══════════════════════════════════════════════════════════════
local buildAPI

buildAPI = function(ts, baseZ)
    baseZ = baseZ or 10
    local api = {}

    function api:AddSection(name)
        local s = mkFrame(ts, {Size=UDim2.new(1,0,0,20), BackgroundTransparency=1, ZIndex=baseZ+1})
        mkLabel(s, {Text=string.upper(name or ""), Size=UDim2.new(1,0,1,0), TextColor3=T.AccentLight, TextSize=9, ZIndex=baseZ+2})
        mkFrame(s, {Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1), BackgroundColor3=T.SideBar2, ZIndex=baseZ+2})
        return s
    end

    function api:AddLabel(text)
        local el  = mkFrame(ts, {Size=UDim2.new(1,0,0,22), BackgroundTransparency=1, ZIndex=baseZ+1})
        local lbl = mkLabel(el, {Text=tostring(text or ""), Size=UDim2.new(1,0,1,0), TextColor3=T.TextSec, TextSize=11, ZIndex=baseZ+2, TextWrapped=true})
        local proxy = setmetatable({}, {
            __index    = function(_, k)
                if k == "Text"   then return lbl.Text end
                if k == "Remove" then return function() el:Destroy() end end
            end,
            __newindex = function(_, k, v)
                if k == "Text" then lbl.Text = tostring(v) end
            end,
        })
        return proxy
    end

    function api:AddButton(lbl, cb)
        lbl = tostring(lbl or "Button"); cb = type(cb)=="function" and cb or function() end
        local el = mkFrame(ts, {Size=UDim2.new(1,0,0,30), BackgroundColor3=T.ElBg, ZIndex=baseZ+1})
        mkCorner(el, 7); mkStroke(el, T.ElBorder, 1, 0.6)
        mkLabel(el, {Text=string.upper(lbl), Size=UDim2.new(1,-32,1,0), Position=UDim2.new(0,10,0,0), TextColor3=T.TextPri, TextSize=11, ZIndex=baseZ+2})
        mkLabel(el, {Text="›", Size=UDim2.fromOffset(18,30), Position=UDim2.new(1,-20,0,0), TextColor3=T.AccentLight, TextSize=14, TextXAlignment=Enum.TextXAlignment.Center, ZIndex=baseZ+2})
        local c = mkBtn(el, {Size=UDim2.new(1,0,1,0), ZIndex=baseZ+3, Text=""})
        c.MouseEnter:Connect(function()  tw(el,{BackgroundColor3=T.ElHover},0.1) end)
        c.MouseLeave:Connect(function()  tw(el,{BackgroundColor3=T.ElBg},0.1) end)
        c.MouseButton1Click:Connect(function()
            tw(el,{BackgroundColor3=T.Accent},0.08)
            task.delay(0.12, function() tw(el,{BackgroundColor3=T.ElBg},0.15) end)
            pcall(cb)
        end)
        return setmetatable({},{__index=function(_,k) if k=="Remove" then return function() el:Destroy() end end end})
    end

    function api:AddToggle(lbl, default, cb)
        lbl = tostring(lbl or "Toggle")
        if type(default)=="function" then cb=default; default=false end
        cb = type(cb)=="function" and cb or function() end
        local st = default==true
        local el = mkFrame(ts, {Size=UDim2.new(1,0,0,30), BackgroundColor3=T.ElBg, ZIndex=baseZ+1})
        mkCorner(el, 7); mkStroke(el, T.ElBorder, 1, 0.6)
        mkLabel(el, {Text=string.upper(lbl), Size=UDim2.new(1,-54,1,0), Position=UDim2.new(0,10,0,0), TextColor3=T.TextPri, TextSize=11, ZIndex=baseZ+2})
        local track = mkFrame(el, {Size=UDim2.fromOffset(34,18), Position=UDim2.new(1,-44,0.5,-9), BackgroundColor3=st and T.TogOn or T.TogOff, ZIndex=baseZ+2})
        mkCorner(track, 9); mkStroke(track, T.ElBorder, 1, 0.4)
        local thumb = mkFrame(track, {Size=UDim2.fromOffset(12,12), Position=st and UDim2.fromOffset(19,3) or UDim2.fromOffset(3,3), BackgroundColor3=Color3.new(1,1,1), ZIndex=baseZ+3})
        mkCorner(thumb, 6)
        local function upd()
            tw(track, {BackgroundColor3=st and T.TogOn or T.TogOff}, 0.15)
            tw(thumb, {Position=st and UDim2.fromOffset(19,3) or UDim2.fromOffset(3,3)}, 0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        end
        local c = mkBtn(el, {Size=UDim2.new(1,0,1,0), ZIndex=baseZ+4, Text=""})
        c.MouseEnter:Connect(function()  tw(el,{BackgroundColor3=T.ElHover},0.1) end)
        c.MouseLeave:Connect(function()  tw(el,{BackgroundColor3=T.ElBg},0.1) end)
        c.MouseButton1Click:Connect(function() st = not st; upd(); pcall(cb, st) end)
        upd()
        local tAPI = {}
        function tAPI:Set(v) st = v==true; upd(); pcall(cb, st) end
        function tAPI:Get() return st end
        return tAPI, el
    end

    -- AddSwitch = old-API alias for AddToggle
    function api:AddSwitch(lbl, cb)
        return api:AddToggle(lbl, false, cb)
    end

    function api:AddSlider(lbl, settings, cb)
        lbl = tostring(lbl or "Slider")
        if type(settings)=="function" then cb=settings; settings={} end
        cb = type(cb)=="function" and cb or function() end
        settings = settings or {}
        local mn=settings.min or 0; local mx=settings.max or 100
        local df=settings.default or mn; local sx=settings.suffix or ""
        local el = mkFrame(ts, {Size=UDim2.new(1,0,0,44), BackgroundColor3=T.ElBg, ZIndex=baseZ+1})
        mkCorner(el, 7); mkStroke(el, T.ElBorder, 1, 0.6)
        mkLabel(el, {Text=string.upper(lbl), Size=UDim2.new(0.65,0,0,20), Position=UDim2.new(0,10,0,3), TextColor3=T.TextPri, TextSize=11, ZIndex=baseZ+2})
        local vLbl = mkLabel(el, {Text=tostring(df)..sx, Size=UDim2.new(0.35,-12,0,20), Position=UDim2.new(0.65,0,0,3), TextColor3=T.AccentLight, TextSize=11, TextXAlignment=Enum.TextXAlignment.Right, ZIndex=baseZ+2})
        local track = mkFrame(el, {Size=UDim2.new(1,-20,0,4), Position=UDim2.new(0,10,0,30), BackgroundColor3=T.ElHover, ZIndex=baseZ+2}); mkCorner(track,2)
        local fill  = mkFrame(track, {Size=UDim2.new(0,0,1,0), BackgroundColor3=T.AccentLight, ZIndex=baseZ+3}); mkCorner(fill,2)
        local knob  = mkFrame(track, {Size=UDim2.fromOffset(10,10), Position=UDim2.new(0,-5,0.5,-5), BackgroundColor3=Color3.new(1,1,1), ZIndex=baseZ+4}); mkCorner(knob,5)
        local cur = df
        local function sp(pct)
            pct = math.clamp(pct,0,1); cur = math.floor(mn+(mx-mn)*pct)
            fill.Size = UDim2.new(pct,0,1,0); knob.Position = UDim2.new(pct,-5,0.5,-5)
            vLbl.Text = tostring(cur)..sx; pcall(cb, cur)
        end
        sp((df-mn)/math.max(mx-mn,1))
        local drg = false
        track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drg=true end end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drg=false end end)
        RunService.Heartbeat:Connect(function() if drg then sp((UserInputService:GetMouseLocation().X-track.AbsolutePosition.X)/track.AbsoluteSize.X) end end)
        local sAPI = {}
        function sAPI:Set(v) sp((v-mn)/math.max(mx-mn,1)) end
        function sAPI:Get() return cur end
        return sAPI, el
    end

    function api:AddDropdown(lbl, cbOrItems, mayCb)
        lbl = tostring(lbl or "Dropdown")
        local cb, items
        if type(cbOrItems)=="function" then cb=cbOrItems; items={}
        elseif type(cbOrItems)=="table" then items=cbOrItems; cb=type(mayCb)=="function" and mayCb or function()end
        else cb=function()end; items={} end

        local sel=items[1]; local open=false
        local el = mkFrame(ts, {Size=UDim2.new(1,0,0,30), BackgroundColor3=T.ElBg, ZIndex=baseZ+1, ClipsDescendants=false})
        mkCorner(el,7); mkStroke(el,T.ElBorder,1,0.6)
        mkLabel(el, {Text=string.upper(lbl), Size=UDim2.new(0.55,0,1,0), Position=UDim2.new(0,10,0,0), TextColor3=T.TextPri, TextSize=11, ZIndex=baseZ+2})
        local sLbl = mkLabel(el, {Text=sel and string.upper(tostring(sel)) or "SELECT...", Size=UDim2.new(0.4,-26,1,0), Position=UDim2.new(0.55,0,0,0), TextColor3=T.AccentLight, TextSize=10, TextXAlignment=Enum.TextXAlignment.Right, ZIndex=baseZ+2})
        local arrow = mkLabel(el, {Text="⌄", Size=UDim2.fromOffset(18,30), Position=UDim2.new(1,-20,0,0), TextColor3=T.AccentLight, TextSize=12, TextXAlignment=Enum.TextXAlignment.Center, ZIndex=baseZ+2})
        local dList = mkFrame(el, {Size=UDim2.new(1,0,0,0), Position=UDim2.new(0,0,1,3), BackgroundColor3=T.ContentAlt, ZIndex=baseZ+20, ClipsDescendants=true, Visible=false})
        mkCorner(dList,7); mkStroke(dList,T.ElBorder,1,0.4)
        local dLay = Instance.new("UIListLayout"); dLay.SortOrder=Enum.SortOrder.LayoutOrder; dLay.Parent=dList
        local dPad = Instance.new("UIPadding"); dPad.PaddingTop=UDim.new(0,3); dPad.PaddingBottom=UDim.new(0,3); dPad.Parent=dList

        local function rebuild()
            for _,c in ipairs(dList:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
            for _,item in ipairs(items) do
                local ib = mkBtn(dList, {Text="  "..string.upper(tostring(item)), Size=UDim2.new(1,0,0,24), BackgroundColor3=T.ContentAlt, BackgroundTransparency=0, TextColor3=item==sel and T.AccentLight or T.TextSec, TextSize=10, ZIndex=baseZ+21})
                ib.MouseEnter:Connect(function() tw(ib,{BackgroundColor3=T.ElHover,TextColor3=T.TextPri},0.08) end)
                ib.MouseLeave:Connect(function() tw(ib,{BackgroundColor3=T.ContentAlt,TextColor3=item==sel and T.AccentLight or T.TextSec},0.08) end)
                ib.MouseButton1Click:Connect(function()
                    sel=item; sLbl.Text=string.upper(tostring(item)); open=false
                    tw(dList,{Size=UDim2.new(1,0,0,0)},0.12); task.delay(0.12,function() dList.Visible=false end)
                    tw(arrow,{Rotation=0},0.12); rebuild(); pcall(cb,item)
                end)
            end
        end
        rebuild()

        local hBtn = mkBtn(el, {Size=UDim2.new(1,0,1,0), ZIndex=baseZ+3, Text=""})
        hBtn.MouseEnter:Connect(function() tw(el,{BackgroundColor3=T.ElHover},0.1) end)
        hBtn.MouseLeave:Connect(function() tw(el,{BackgroundColor3=T.ElBg},0.1) end)
        hBtn.MouseButton1Click:Connect(function()
            open = not open
            if open then
                dList.Visible=true; local h=math.min(#items*24+6,140)
                tw(dList,{Size=UDim2.new(1,0,0,h)},0.12); tw(arrow,{Rotation=180},0.12)
            else
                tw(dList,{Size=UDim2.new(1,0,0,0)},0.12); task.delay(0.12,function() dList.Visible=false end)
                tw(arrow,{Rotation=0},0.12)
            end
        end)

        local ddAPI = {}
        function ddAPI:Add(name)     name=tostring(name); for _,v in ipairs(items) do if v==name then return end end; table.insert(items,name); rebuild() end
        function ddAPI:Remove(name)  name=tostring(name); for i,v in ipairs(items) do if v==name then table.remove(items,i); break end end; if sel==name then sel=items[1]; sLbl.Text=sel and string.upper(tostring(sel)) or "SELECT..." end; rebuild() end
        function ddAPI:Set(v)        sel=v; sLbl.Text=string.upper(tostring(v)); rebuild() end
        function ddAPI:Get()         return sel end
        function ddAPI:SetItems(t)   items=t; rebuild() end
        function ddAPI:ClearSelection() sel=nil; sLbl.Text="SELECT..." end
        function ddAPI:ClearOptions()   items={}; sel=nil; sLbl.Text="SELECT..."; rebuild() end
        return ddAPI, el
    end

    function api:AddTextBox(lbl, cb)
        lbl = tostring(lbl or "Input"); cb = type(cb)=="function" and cb or function() end
        local el = mkFrame(ts, {Size=UDim2.new(1,0,0,30), BackgroundColor3=T.ElBg, ZIndex=baseZ+1})
        mkCorner(el,7); mkStroke(el,T.ElBorder,1,0.6)
        mkLabel(el, {Text=string.upper(lbl), Size=UDim2.new(0.45,0,1,0), Position=UDim2.new(0,10,0,0), TextColor3=T.TextPri, TextSize=11, ZIndex=baseZ+2})
        local tb = Instance.new("TextBox"); tb.Parent=el
        tb.Size=UDim2.new(0.5,-8,0,20); tb.Position=UDim2.new(0.48,0,0.5,-10)
        tb.BackgroundColor3=T.ContentAlt; tb.BorderSizePixel=0
        tb.Font=Enum.Font.GothamBold; tb.TextSize=10; tb.TextColor3=T.TextPri
        tb.PlaceholderColor3=T.TextMut; tb.PlaceholderText="Enter..."; tb.Text=""
        tb.ClearTextOnFocus=false; tb.ZIndex=baseZ+3; mkCorner(tb,5)
        local p=Instance.new("UIPadding"); p.PaddingLeft=UDim.new(0,5); p.PaddingRight=UDim.new(0,5); p.Parent=tb
        tb.Focused:Connect(function() tw(tb,{BackgroundColor3=T.ElHover},0.1) end)
        tb.FocusLost:Connect(function(enter) tw(tb,{BackgroundColor3=T.ContentAlt},0.1); if enter and #tb.Text>0 then pcall(cb,tb.Text) end end)
        return tb, el
    end

    function api:AddInput(lbl, placeholder, cb)
        if type(placeholder)=="function" then cb=placeholder end
        return api:AddTextBox(lbl, cb)
    end

    function api:AddKeybind(lbl, default, cb)
        lbl = tostring(lbl or "Keybind")
        if type(default)=="function" then cb=default; default=Enum.KeyCode.Unknown end
        cb = type(cb)=="function" and cb or function() end
        local cur = (type(default)=="EnumItem") and default or Enum.KeyCode.Unknown
        local el = mkFrame(ts, {Size=UDim2.new(1,0,0,30), BackgroundColor3=T.ElBg, ZIndex=baseZ+1})
        mkCorner(el,7); mkStroke(el,T.ElBorder,1,0.6)
        mkLabel(el, {Text=string.upper(lbl), Size=UDim2.new(0.6,0,1,0), Position=UDim2.new(0,10,0,0), TextColor3=T.TextPri, TextSize=11, ZIndex=baseZ+2})
        local kBtn = mkBtn(el, {Text=cur~=Enum.KeyCode.Unknown and cur.Name or "NONE", Size=UDim2.new(0,62,0,20), Position=UDim2.new(1,-72,0.5,-10), BackgroundColor3=T.ContentAlt, BackgroundTransparency=0, TextColor3=T.AccentLight, TextSize=9, ZIndex=baseZ+3})
        mkCorner(kBtn,5); mkStroke(kBtn,T.ElBorder,1,0.4)
        local lstn = false
        kBtn.MouseButton1Click:Connect(function()
            if lstn then return end; lstn=true; kBtn.Text="..."; bindingActive=true
            tw(kBtn,{BackgroundColor3=T.ElHover},0.1)
            local conn; conn=UserInputService.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.Keyboard then
                    cur=i.KeyCode; kBtn.Text=i.KeyCode.Name; lstn=false; bindingActive=false
                    tw(kBtn,{BackgroundColor3=T.ContentAlt},0.1); conn:Disconnect()
                end
            end)
        end)
        UserInputService.InputBegan:Connect(function(i,gp)
            if not gp and cur and i.KeyCode==cur and not lstn then pcall(cb,cur) end
        end)
        local kAPI = {}; function kAPI:Set(k) cur=k; kBtn.Text=k.Name end
        return kAPI, el
    end

    function api:AddSeparator()
        local s = mkFrame(ts, {Size=UDim2.new(1,0,0,6), BackgroundTransparency=1, ZIndex=baseZ+1})
        mkFrame(s, {Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,0.5,0), BackgroundColor3=T.SideBar2, ZIndex=baseZ+2})
        return s
    end

    function api:AddColorPicker(lbl, default, cb)
        lbl = tostring(lbl or "Color")
        if type(default)=="function" then cb=default; default=T.Accent end
        cb = type(cb)=="function" and cb or function() end
        local col = default or T.Accent
        local el = mkFrame(ts, {Size=UDim2.new(1,0,0,30), BackgroundColor3=T.ElBg, ZIndex=baseZ+1})
        mkCorner(el,7); mkStroke(el,T.ElBorder,1,0.6)
        mkLabel(el, {Text=string.upper(lbl), Size=UDim2.new(0.65,0,1,0), Position=UDim2.new(0,10,0,0), TextColor3=T.TextPri, TextSize=11, ZIndex=baseZ+2})
        local prev = mkFrame(el, {Size=UDim2.fromOffset(20,20), Position=UDim2.new(1,-30,0.5,-10), BackgroundColor3=col, ZIndex=baseZ+2})
        mkCorner(prev,5); mkStroke(prev,T.ElBorder,1,0.3)
        local cAPI = {}
        function cAPI:Set(c) col=c; prev.BackgroundColor3=c; pcall(cb,c) end
        function cAPI:Get() return col end
        return cAPI, el
    end

    -- ── AddFolder ── fully recursive via module-level buildAPI ──
    function api:AddFolder(folderName)
        folderName = tostring(folderName or "Folder")

        local container = mkFrame(ts, {
            Size=UDim2.new(1,0,0,26), BackgroundColor3=T.FolderBg,
            ZIndex=baseZ+1, ClipsDescendants=true
        })
        mkCorner(container,7); mkStroke(container,T.AccentDark,1,0.5)

        local hdr = mkFrame(container, {Size=UDim2.new(1,0,0,26), BackgroundColor3=T.FolderHead, ZIndex=baseZ+2})
        mkCorner(hdr,7)
        mkFrame(hdr, {Size=UDim2.new(1,0,0.5,0), Position=UDim2.new(0,0,0.5,0), BackgroundColor3=T.FolderHead, ZIndex=baseZ+2})
        mkLabel(hdr, {Text="  "..string.upper(folderName), Size=UDim2.new(1,-24,1,0), TextColor3=T.AccentLight, TextSize=11, ZIndex=baseZ+3})
        local arrLbl = mkLabel(hdr, {Text="▶", Size=UDim2.fromOffset(20,26), Position=UDim2.new(1,-22,0,0), TextColor3=T.TextMut, TextSize=9, TextXAlignment=Enum.TextXAlignment.Center, ZIndex=baseZ+3})

        local inner = Instance.new("ScrollingFrame"); inner.Parent=container
        inner.Size=UDim2.new(1,0,1,-26); inner.Position=UDim2.new(0,0,0,26)
        inner.BackgroundTransparency=1; inner.BorderSizePixel=0
        inner.ScrollBarThickness=2; inner.ScrollBarImageColor3=T.AccentLight
        inner.ScrollBarImageTransparency=0.5; inner.CanvasSize=UDim2.new(0,0,0,0)
        inner.ZIndex=baseZ+3; inner.ClipsDescendants=true

        local iLay=Instance.new("UIListLayout"); iLay.SortOrder=Enum.SortOrder.LayoutOrder; iLay.Padding=UDim.new(0,4); iLay.Parent=inner
        local iPad=Instance.new("UIPadding"); iPad.PaddingLeft=UDim.new(0,6); iPad.PaddingRight=UDim.new(0,6); iPad.PaddingTop=UDim.new(0,5); iPad.PaddingBottom=UDim.new(0,5); iPad.Parent=inner

        local isOpen = false
        local function updateSize()
            local ch = iLay.AbsoluteContentSize.Y + 16
            inner.CanvasSize = UDim2.new(0,0,0,ch)
            if isOpen then
                local tot = math.min(ch+26, 300)
                tw(container, {Size=UDim2.new(1,0,0,tot)}, 0.2)
                inner.Size = UDim2.new(1,0,0,tot-26)
            end
        end
        iLay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() if isOpen then updateSize() end end)

        local hBtn = mkBtn(hdr, {Size=UDim2.new(1,0,1,0), ZIndex=baseZ+4, Text=""})
        hBtn.MouseEnter:Connect(function() tw(hdr,{BackgroundColor3=T.ElHover},0.1) end)
        hBtn.MouseLeave:Connect(function() tw(hdr,{BackgroundColor3=T.FolderHead},0.1) end)
        hBtn.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            if isOpen then tw(arrLbl,{Rotation=90},0.15); updateSize()
            else tw(arrLbl,{Rotation=0},0.15); tw(container,{Size=UDim2.new(1,0,0,26)},0.2) end
        end)

        -- recurse using module-level buildAPI
        local folderAPI = buildAPI(inner, baseZ+5)
        return folderAPI, container
    end

    return api
end

